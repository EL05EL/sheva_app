<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- ============================================================= -->
    <!-- 📌 IZIN PERANGKAT (Harus di luar tag <application>)           -->
    <!-- ============================================================= -->
    
    <!-- Izin Internet (wajib untuk semua aplikasi) -->
    <uses-permission android:name="android.permission.INTERNET" />
    
    <!-- Izin Lokasi (GPS & Jaringan) untuk fitur deteksi otomatis -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    
    <!-- Izin Kamera untuk mengambil foto bukti -->
    <uses-permission android:name="android.permission.CAMERA" />
    
    <!-- Izin Galeri/Storage untuk memilih foto dari galeri -->
    <!-- android:maxSdkVersion="32" artinya izin ini hanya diminta untuk Android 12 ke bawah,
         karena Android 13+ menggunakan izin terpisah (READ_MEDIA_IMAGES) yang ditangani otomatis oleh image_picker -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    
    <!-- Untuk Android 11+, memungkinkan aplikasi mendeteksi paket WhatsApp, Maps, dsb. -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <!-- ============================================================= -->
    <!-- 📦 APLIKASI                                                   -->
    <!-- ============================================================= -->
    
    <application
        android:label="sheva_app"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:usesCleartextTraffic="true"
        android:allowBackup="true"
        android:requestLegacyExternalStorage="true">
        
        <!-- Aktivitas Utama -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            
            <!-- Tema Normal untuk Flutter -->
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
            
            <!-- Intent Filter Launcher -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            
        </activity>
        
        <!-- Jangan hapus meta-data di bawah ini.
             Digunakan oleh Flutter untuk generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
            
    </application>

    <!-- ============================================================= -->
    <!-- 🔍 QUERIES (Visibilitas Paket untuk url_launcher)             -->
    <!-- ============================================================= -->
    <!--
         Tag <queries> wajib di Android 11+ agar aplikasi bisa 
         mendeteksi dan membuka aplikasi lain seperti:
         - WhatsApp (https://wa.me)
         - Google Maps (geo://, https://maps.google.com)
         - Aplikasi Telepon (tel://)
         - SMS (sms://)
    -->
    <queries>
        
        <!-- Query bawaan Flutter untuk proses teks -->
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>
        
        <!-- 🔥 Query untuk membuka LINK HTTPS (WhatsApp, Website, Google Maps Web) -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        
        <!-- 🔥 Query untuk membuka LINK HTTP (fallback) -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="http" />
        </intent>
        
        <!-- 🔥 Query untuk membuka NOMOR TELEPON (dialer) -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="tel" />
        </intent>
        
        <!-- 🔥 Query untuk membuka GOOGLE MAPS (geo://) -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="geo" />
        </intent>
        
        <!-- 🔥 Query untuk membuka SMS (fallback jika WhatsApp gagal) -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="sms" />
        </intent>
        
    </queries>
    
</manifest>